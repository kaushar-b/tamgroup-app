{
  "expo": {
    "name": "TAM Restaurant Group",
    "slug": "tamgroup-app",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "light",
    "newArchEnabled": false,
    "owner": "starkey1.8",
    "splash": {
      "image": "./assets/splash-icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#FADAD9"
    },
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.starkey18.tamgroup"
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#FADAD9"
      },
      "edgeToEdgeEnabled": true,
      "package": "com.starkey18.tamgroup"
    },
    "web": {
      "favicon": "./assets/favicon.png"
    },
    "extra": {
      "eas": {
        "projectId": "c84c3e07-ea75-473c-8cc2-559656440c71"
      }
    },
    "plugins": [
      "expo-font",
      "expo-secure-store"
    ]
  }
}
